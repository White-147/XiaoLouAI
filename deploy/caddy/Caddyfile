# XiaoLouAI Windows-native Caddy config.
# Production serves the built frontend from .runtime/app and proxies only the
# approved public Control API routes to the .NET service on 127.0.0.1:4100.

(xiaolou_site) {
	root * D:/code/XiaoLouAI/.runtime/app/XIAOLOU-main/dist

	handle /api/internal/* {
		respond 404
	}

	handle /api/schema* {
		respond 404
	}

	handle /api/providers/health* {
		respond 404
	}

	handle /metrics {
		respond 404
	}

	handle /healthz {
		reverse_proxy 127.0.0.1:4100
	}

	handle /livez {
		reverse_proxy 127.0.0.1:4100
	}

	handle /readyz {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/windows-native/status {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/capabilities {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/accounts/ensure {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/auth* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/me {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/organizations* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/api-center* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/admin* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/enterprise-applications* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/playground* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/toolbox* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/jobs* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/wallet {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/wallet/usage-stats {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/wallets {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/wallets/* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/payments/callbacks/* {
		reverse_proxy 127.0.0.1:4100
	}

	# Provider callback aliases are exposed only for payment-provider cutover
	# compatibility. Frontend legacy writes stay blocked below.
	handle /api/payments/alipay/notify {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/payments/wechat/notify {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/upload-begin {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/upload-complete {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/move-temp-to-permanent {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/signed-read-url {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/projects* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/canvas-projects* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/agent-canvas/projects* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/create/images* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/create/videos* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/* {
		respond 404
	}

	handle /uploads/* {
		respond 404
	}

	handle /jaaz* {
		respond 404
	}

	handle /jaaz-api* {
		respond 404
	}

	handle /socket.io/* {
		respond 404
	}

	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server {
			precompressed br gzip
		}
	}

	handle {
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server {
			precompressed br gzip
		}
	}
}

www.xiaolouai.cn {
	import xiaolou_site

	log {
		output stdout
	}
}

http://www.xiaolou.cn, http://xiaolou.cn {
	import xiaolou_site

	log {
		output stdout
	}
}

http://www.aitianmu.cn, http://aitianmu.cn {
	import xiaolou_site

	log {
		output stdout
	}
}

:80 {
	import xiaolou_site
}

:8080 {
	import xiaolou_site
}
