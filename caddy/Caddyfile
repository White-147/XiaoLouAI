# XiaoLouAI Windows-native Caddy config.
# Production serves the built frontend from dist and proxies API traffic to
# the .NET control plane Windows Service on 127.0.0.1:4100.

(xiaolou_api_proxy) {
	handle /api/internal/* {
		respond 404
	}

	handle /api/schema* {
		respond 404
	}

	handle /api/providers/health* {
		respond 404
	}

	handle /healthz {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/accounts/ensure {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/jobs* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/payments/callbacks/* {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/upload-begin {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/upload-complete {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/move-temp-to-permanent {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/media/signed-read-url {
		reverse_proxy 127.0.0.1:4100
	}

	handle /api/* {
		respond 404
	}

	handle /uploads/* {
		respond 404
	}

	handle /jaaz* {
		respond 404
	}

	handle /jaaz-api* {
		respond 404
	}

	handle /socket.io/* {
		respond 404
	}
}

(xiaolou_static_frontend) {
	root * D:/code/XiaoLouAI/.runtime/app/XIAOLOU-main/dist
	try_files {path} /index.html
	file_server
}

www.xiaolouai.cn {
	import xiaolou_api_proxy
	import xiaolou_static_frontend

	log {
		output stdout
	}
}

http://www.xiaolou.cn, http://xiaolou.cn {
	import xiaolou_api_proxy
	import xiaolou_static_frontend

	log {
		output stdout
	}
}

http://www.aitianmu.cn, http://aitianmu.cn {
	import xiaolou_api_proxy
	import xiaolou_static_frontend

	log {
		output stdout
	}
}

:80 {
	import xiaolou_api_proxy
	import xiaolou_static_frontend
}

:8080 {
	import xiaolou_api_proxy
	import xiaolou_static_frontend
}
