# Copy this file to .env before running `docker compose`.
# Local/developer defaults intentionally use root/root for quick access.
# Replace every password before a shared or internet-facing deployment.

# PostgreSQL is optional in docker-compose via the `postgres` profile.
# The default local path uses an existing host PostgreSQL on 127.0.0.1:5432.
# Enable the compose PostgreSQL only for isolated/new-machine testing.
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=xiaolou
# Use 55432 by default to avoid colliding with an existing host PostgreSQL on 5432.
POSTGRES_PORT=55432

RABBITMQ_DEFAULT_USER=root
RABBITMQ_DEFAULT_PASS=root
RABBITMQ_DEFAULT_VHOST=xiaolou
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

REDIS_PASSWORD=root
REDIS_PORT=6379

# services/api host-mode connection strings
DATABASE_URL=postgres://root:root@127.0.0.1:55432/xiaolou
READ_DATABASE_URL=postgres://root:root@127.0.0.1:55432/xiaolou
PGBOUNCER_DATABASE_URL=
RABBITMQ_URL=amqp://root:root@127.0.0.1:5672/xiaolou
REDIS_URL=redis://:root@127.0.0.1:6379/0
