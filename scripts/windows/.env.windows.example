PAYMENT_WEBHOOK_SECRET=change-me
# Real Alipay/WeChat merchant secrets are never committed to this repository.
# Store key/certificate files under:
#   D:\code\XiaoLouAI\.runtime\app\credentials\payment\
# The current Windows-native Control API callback verifier accepts normalized
# canonical JSON signed with Payments__<provider>__WebhookSecret. Raw Alipay
# RSA2 form callbacks or WeChat Pay v3 encrypted notifications require the
# provider adapter/normalizer to be enabled before direct .NET replay.
PAYMENT_CALLBACK_ALLOWED_PROVIDERS=testpay,alipay,wechat
PAYMENT_CALLBACK_REQUIRE_ALLOWED_PROVIDER=true
# Gray-release account gate for payment callbacks. Keep false for isolated
# local smoke; set true with one explicit canary account/owner before public
# provider callback routing.
PAYMENT_CALLBACK_REQUIRE_ACCOUNT_GRANT=false
PAYMENT_CALLBACK_ALLOWED_ACCOUNT_IDS=
PAYMENT_CALLBACK_ALLOWED_ACCOUNT_OWNER_IDS=
Payments__alipay__WebhookSecret=
Payments__wechat__WebhookSecret=
ALIPAY_ENV=
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
INTERNAL_API_TOKEN=change-me-internal-token
CLIENT_API_TOKEN=change-me-client-token
CLIENT_API_TOKEN_HEADER=X-XiaoLou-Client-Token
CLIENT_API_AUTH_PROVIDER=
