# Open WebUI / Playground configuration
# -------------------------------------------------
# Copy this file to openwebui.env.local and fill in your values.
# openwebui.env.local is gitignored — never commit real keys.
# -------------------------------------------------

# Your Ark / OpenAI-compatible API key for Open WebUI model calls.
# Get yours from: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
OPENAI_API_KEY=YOUR_ARK_OR_OPENAI_API_KEY

# The public URL where Open WebUI is served (used by the container internally).
# For local-only: http://127.0.0.1:8080
# For public domain: http://yourdomain.com/openwebui
WEBUI_PUBLIC_URL=http://127.0.0.1:8080

# Optional: override the OpenAI-compatible base URL (default: Volcengine Ark)
# CUSTOM_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
