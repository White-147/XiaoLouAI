# XiaoLouAI PostgreSQL runtime switch
# Copy these lines into core-api/.env.local after importing SQLite.

DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
DATABASE_PUBLIC_URL="postgres://root:root@218.92.180.214:5432/xiaolou"
VR_DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
JAAZ_DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
PGPOOL_MAX="10"
PGSSL_MODE="disable"
POSTGRES_ALLOW_EMPTY_BOOTSTRAP="0"

# PostgreSQL server-side network settings to apply on 218.92.180.214.
# Use db/configure-postgres-network.ps1 instead of editing these files by hand.
POSTGRES_LISTEN_ADDRESSES="localhost,218.92.180.214"
POSTGRES_ALLOWED_CLIENT_CIDRS="127.0.0.1/32,::1/128,218.92.180.214/32"
