# ============================================================
# core-api 环境变量配置
# ============================================================
# 复制此文件为 .env.local 并填入真实值
# .env.local 已被 gitignore，不会提交到仓库

# ------ 必填 ------
# Yunwu 网关 — 图片/视频生成（主要调用渠道）
YUNWU_BASE_URL="https://yunwu.ai"
YUNWU_API_KEY="YOUR_YUNWU_API_KEY"

# Google OAuth login (optional)
# Add this redirect URI in Google Cloud Console:
#   http://localhost:3001/api/auth/google/callback
# GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
# GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"
# XIAOLOU_FRONTEND_ORIGIN="http://localhost:3001"

# ------ 可选 ------

# Volcengine Ark — Seedance 2.0 视频生成（字节火山引擎）
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
# VOLCENGINE_ARK_API_KEY="YOUR_ARK_API_KEY"

# PixVerse OpenAPI v2 视频生成
# PIXVERSE_BASE_URL="https://app-api.pixverse.ai/openapi/v2"
# PIXVERSE_API_KEY="YOUR_PIXVERSE_API_KEY"

# DashScope（旧版文本/视觉调用，可选）
# DASHSCOPE_API_KEY="YOUR_DASHSCOPE_API_KEY"

# Qwen3.5-Omni — 视频反推提示词（/create/video-reverse）
# 华北2（北京）compatible-mode：https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选 model：qwen3.5-omni-flash（默认，推荐）/ qwen3.5-omni-plus（高质）/
#            qwen3.5-omni-light（低延迟）/ qwen-omni-turbo（旧版回退）
# 旧值 qwen3-omni-plus 在 DashScope 上不存在，会返回 404。
# QWEN_OMNI_API_KEY="YOUR_QWEN_OMNI_API_KEY"
# QWEN_OMNI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# QWEN_OMNI_MODEL="qwen3.5-omni-flash"

# ── Official Google Vertex AI (Gemini Image + Veo Video) ──
# Required for vertex:* models (Gemini 3 Pro Image+, Gemini 3.1 Flash Image+, Veo 3.1+, etc.)
#
# VERTEX_PROJECT_ID="xldm-test-01"           # GCP project ID
# VERTEX_GEMINI_LOCATION="global"            # Gemini API location (default: global)
# VERTEX_VEO_LOCATION="us-central1"          # Veo API location (default: us-central1)
# VERTEX_GCS_BUCKET="gs://my-xiaolou-veo-output"  # GCS bucket for Veo video output
#
# Authentication — choose ONE of the following:
# Option A: Vertex AI API Key (create in Cloud Console > APIs & Services > Credentials)
# VERTEX_API_KEY="YOUR_VERTEX_API_KEY"
#
# Option B: Service Account JSON (download from Cloud Console > IAM > Service Accounts)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ------ Alipay real recharge payments (optional) ------
# First connect sandbox, then switch ALIPAY_ENV to production after end-to-end
# verification. This project uses RSA2 public-key mode, not certificate mode.
# Alipay console callback URLs:
#   async notify_url: https://www.xiaolouai.cn/api/payments/alipay/notify
#   return_url:       https://www.xiaolouai.cn/wallet/recharge
# ALIPAY_ENV="sandbox" # sandbox | production
# ALIPAY_APP_ID="YOUR_ALIPAY_APP_ID"
# ALIPAY_PRIVATE_KEY_PATH="./credentials/alipay-app-private-key.pem"
# ALIPAY_PUBLIC_KEY_PATH="./credentials/alipay-public-key.pem"
# ALIPAY_SELLER_ID="YOUR_ALIPAY_SELLER_ID"
# PAY_PUBLIC_BASE_URL="https://www.xiaolouai.cn"
# PAY_RETURN_BASE_URL="https://www.xiaolouai.cn"
# RECHARGE_CREDITS_PER_RMB="2"
#
# Mock recharge visibility. "*" makes the demo mock payment card visible from
# every host/IP. Replace with a comma-separated host list to restrict it later.
PAYMENT_MOCK_ALLOWED_HOSTS="*"
#
# Excluded models (do NOT configure these):
#   gemini-3-pro-preview  → discontinued by Google 2026-03-26
#   veo-3.1-generate-preview / veo-3.1-fast-generate-preview → removed 2026-04-02

# ------ 服务配置（可选覆盖） ------
# PORT="4100"
# HOST="::"   # :: = 全部接口; 127.0.0.1 = 仅本地
# CORE_API_PUBLIC_BASE_URL="https://your-domain.com"   # 单域名公网模式
# DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
# DATABASE_PUBLIC_URL="postgres://root:root@218.92.180.214:5432/xiaolou"
# VR_DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
# JAAZ_DATABASE_URL="postgres://root:root@127.0.0.1:5432/xiaolou"
# PGPOOL_MAX="10"
# PGSSL_MODE="disable"                                 # disable | require
# POSTGRES_ALLOW_EMPTY_BOOTSTRAP="0"                   # keep 0 until SQLite import is complete
# CORE_API_DB_PATH="./data/demo.sqlite"                # migration-only SQLite import source
# CORE_API_UPLOAD_DIR="./uploads"                      # 上传目录（相对于 core-api/）
#
# Jaaz Agent Studio 自启动/保活（可选覆盖）
# JAAZ_AUTO_START="1"          # 设为 0 可关闭 core-api 自动拉起 Jaaz
# JAAZ_KEEPALIVE_MS="30000"    # core-api 后台探活间隔
# JAAZ_API_PORT="57988"
# JAAZ_UI_PORT="5174"
# JAAZ_ROOT="jaaz"
# JAAZ_FILES_DIR="jaaz/server/user_data/files"
# JAAZ_PYTHON="jaaz/.venv/Scripts/python.exe"

# ------ 正式超级管理员账号（公网后台登录） ------
# 配置后后端启动时会自动创建或更新该 super_admin 账号。
# 登录入口：https://www.xiaolouai.cn/admin/login
# SUPER_ADMIN_EMAIL="admin@xiaolouai.cn"
# SUPER_ADMIN_PASSWORD="CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD"
# SUPER_ADMIN_DISPLAY_NAME="超级管理员"
