# ============================================================
# XiaoLou frontend configuration
# ============================================================
# Copy this file to .env.local and fill in local values.
# .env.local is ignored by git.

# Core API
VITE_CORE_API_BASE_URL="http://127.0.0.1:4100"
VITE_CORE_API_PROXY_TARGET="http://127.0.0.1:4100"

# Jaaz Agent Studio
VITE_JAAZ_AGENT_CANVAS_URL="/jaaz/?embed=xiaolou"
VITE_JAAZ_DEV_PROXY_TARGET="http://localhost:5174"
VITE_JAAZ_API_PROXY_TARGET="http://127.0.0.1:57988"

# Public deployment example
# VITE_CORE_API_BASE_URL="https://your-domain.com"

# Canvas is compiled into the main frontend and served by core-api (4100).
