# ============================================================
# XiaoLou 前端配置
# ============================================================
# 复制此文件为 .env.local 并填入真实值
# .env.local 已被 gitignore，不会提交到仓库

# 后端 API 地址（本地开发默认值，通常不需要修改）
VITE_CORE_API_BASE_URL="http://127.0.0.1:4100"
VITE_CORE_API_PROXY_TARGET="http://127.0.0.1:4100"

# Playground / Open WebUI（可选）
VITE_OPEN_WEBUI_URL="/openwebui"
VITE_OPEN_WEBUI_PROXY_TARGET="http://127.0.0.1:8080"

# ============================================================
# 单域名公网部署
# ============================================================
# 将 VITE_CORE_API_BASE_URL 改为你的公网域名：
# VITE_CORE_API_BASE_URL="https://your-domain.com"

# ============================================================
# 说明
# ============================================================
# 画布创作（/create/canvas）已直接编译进主项目（src/canvas/），
# 由 core-api (4100) 提供后端，不需要额外端口或环境变量。
