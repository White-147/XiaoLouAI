# ============================================================
# Video Replace Service — configuration
# Copy to .env.local and fill in values. .env.local is gitignored.
# ============================================================

# ------ API server (LEGACY FastAPI variant — NOT default) ----------------
# The default stack is core-api 4100-native — no FastAPI HTTP listener.
# Python is invoked by core-api as on-demand CLI subprocesses:
#   vr_probe_cli.py / vr_detect_cli.py / vr_pipeline_cli.py.
#
# The variables below are consumed ONLY by run_api.py / app/main.py when
# you explicitly set VR_LEGACY_STANDALONE=1. They default to 4201 (moved
# off the historical 4200 so accidentally starting this debug variant
# can't silently mimic the retired sidecar).
#
# VR_HOST=127.0.0.1
# VR_PORT=4201
# VR_CORS_ORIGINS=http://localhost:4100,http://127.0.0.1:4100

# ------ Storage ------
VR_STORAGE_ROOT=./data
VR_WEIGHTS_ROOT=./weights
VR_MAX_UPLOAD_MB=500

# ------ Task database ------
VR_DATABASE_URL=postgres://root:root@127.0.0.1:5432/xiaolou

# ------ Pipeline tuning ------
VR_MAX_VIDEO_SECONDS=15
VR_DETECTION_KEYFRAME=middle

# ------ Replacement mode ------
# full = SAM2 + VACE/Wan2.1 only. Fail the job (with a detailed message)
#        whenever a dependency / weight is missing. Recommended.
# lite = OpenCV CSRT + compositor, forced. Debug only — the UI badges the
#        result so the user knows it is NOT a real DL replacement.
# auto = legacy: prefer full, fall back to lite silently (not recommended).
VR_REPLACE_MODE=full

# ------ Finalization (H.264/AAC transcode + audio mux) ------
# Optional absolute path to ffmpeg. Falls back to imageio-ffmpeg bundled
# binary when empty and no system ffmpeg is on PATH.
# VR_FFMPEG_BIN=
# VR_FFPROBE_BIN=
VR_FINALIZE_VIDEO_PRESET=veryfast
VR_FINALIZE_VIDEO_CRF=20

# ------ SAM2 ------
VR_SAM2_SIZE_DEFAULT=tiny
VR_SAM2_CHECKPOINT_TINY=./weights/sam2/sam2.1_hiera_tiny.pt
# VR_SAM2_CHECKPOINT_SMALL=./weights/sam2/sam2.1_hiera_small.pt
# VR_SAM2_CHECKPOINT_BASE_PLUS=./weights/sam2/sam2.1_hiera_base_plus.pt
VR_SAM2_AUTO_DOWNLOAD=true

# ------ VACE / Wan2.1 ------
# Clone: git clone https://github.com/Wan-Video/Wan2.1.git ./weights/wan2/Wan2.1
VR_WAN2_REPO_DIR=./weights/wan2/Wan2.1
# Weights: huggingface-cli download Wan-AI/Wan2.1-VACE-1.3B --local-dir ./weights/vace-1.3B
VR_VACE_MODEL_DIR=./weights/vace-1.3B

# ------ YOLOv8 ------
VR_YOLO_WEIGHTS=yolov8n.pt
VR_YOLO_CONF_DEFAULT=0.40
VR_YOLO_DEVICE=cuda

# ------ External service origins ------
VR_CORE_API_BASE_URL=http://127.0.0.1:4100
